{
  "skipDangerousModePermissionPrompt": true,
  "skillListingBudgetFraction": 0.02,
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/scripts/statusline.sh"
  },
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./secrets/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "python3 $HOME/.claude/hooks/no-secrets.py" },
          { "type": "command", "command": "python3 $HOME/.claude/hooks/import-path-validator.py" },
          { "type": "command", "command": "python3 $HOME/.claude/hooks/sveltekit-route-validator.py" },
          { "type": "command", "command": "python3 $HOME/.claude/hooks/drizzle-migration-guard.py" },
          { "type": "command", "command": "python3 $HOME/.claude/hooks/supabase-rls-reminder.py" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/rtk-rewrite.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "python3 $HOME/.claude/hooks/auto-format.py" },
          { "type": "command", "command": "python3 $HOME/.claude/hooks/typecheck-after-edit.py" },
          { "type": "command", "command": "python3 $HOME/.claude/hooks/dependency-audit.py" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 $HOME/.claude/hooks/sveltekit-perf-guard.py" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python3 $HOME/.claude/hooks/stop-verify-and-log.py" }
        ]
      }
    ]
  }
}
