{
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/scripts/statusline.sh"
  },
  "fileSuggestion": {
    "type": "command",
    "command": "$HOME/.claude/scripts/file-suggest.sh"
  },
  "autoMemoryDirectory": ".claude/memory",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-6[1m]",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Read(//Users/piotrek/repos/**)",
      "Read(//Users/piotrek/.claude/**)",
      "Edit(//Users/piotrek/repos/**)",
      "Write(//Users/piotrek/.claude/**)",
      "WebSearch",
      "WebFetch(domain:vite.dev)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:svelte.dev)",
      "WebFetch(domain:kit.svelte.dev)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:drizzle.team)",
      "WebFetch(domain:supabase.com)",
      "mcp__svelte__get-documentation",
      "mcp__svelte-llm__list_sections",
      "mcp__svelte-llm__get_documentation",
      "mcp__ide__getDiagnostics",
      "mcp__gemini-cli__ask-gemini",
      "mcp__supabase__get_advisors",
      "mcp__supabase__execute_sql",
      "mcp__supabase__get_logs",
      "mcp__supabase__list_projects",
      "mcp__vercel__search_vercel_documentation",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_take_screenshot",
      "Skill(frontend-design)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(shasum *)",
      "Bash(printenv *)",
      "Bash(curl *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(timeout *)",
      "Bash(wait)",
      "Bash(mkdir *)",
      "Bash(chmod *)",
      "Bash(tee *)",
      "Bash(xargs *)",
      "Bash(pnpm dev *)",
      "Bash(pnpm build *)",
      "Bash(pnpm check *)",
      "Bash(pnpm check:light *)",
      "Bash(pnpm tsc *)",
      "Bash(pnpm svelte-check *)",
      "Bash(pnpm vitest run *)",
      "Bash(pnpm test:e2e *)",
      "Bash(pnpm test:integration *)",
      "Bash(pnpm db:generate *)",
      "Bash(pnpm db:migrate *)",
      "Bash(pnpm db:studio *)",
      "Bash(pnpm tsx *)",
      "Bash(pnpm exec *)",
      "Bash(pnpm --filter *)",
      "Bash(pnpm update *)",
      "Bash(pnpm remove *)",
      "Bash(vitest run *)",
      "Bash(pnpm view *)",
      "Bash(NODE_OPTIONS= *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git mv *)",
      "Bash(git -C *)",
      "Bash(git push *)",
      "Bash(docker exec *)",
      "Bash(psql *)",
      "Bash(pnpm install *)",
      "Bash(pnpm add *)",
      "Bash(pnpm rebuild *)",
      "Bash(fnm *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(gh *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./secrets/**)",
      "Read(**/node_modules/**)",
      "Read(**/.svelte-kit/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/__pycache__/**)",
      "Read(**/*.lock)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Bash(sudo rm *)",
      "Bash(sudo chmod *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(DROP *)",
      "Bash(DELETE FROM *)",
      "Bash(TRUNCATE *)"
    ],
    "defaultMode": "default"
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/task-restore.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title '🤖 Claude' -message 'Awaiting your input' -sound Ping"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/lessons-loader.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/stop-verify-and-log.py"
          },
          {
            "type": "command",
            "command": "terminal-notifier -title \"🤖 Claude\" -subtitle \"Task Done\" -message \"Completed work in $(basename \"$PWD\")\" -sound Glass -timeout 10"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git *)|Bash(gh *)|Bash(cargo *)|Bash(pnpm *)|Bash(npx *)|Bash(vitest *)|Bash(tsc *)|Bash(svelte-check *)|Bash(eslint *)|Bash(prettier *)|Bash(lint *)|Bash(playwright *)|Bash(prisma *)|Bash(docker *)|Bash(kubectl *)|Bash(curl *)|Bash(pytest *)|Bash(python -m pytest *)|Bash(ruff *)|Bash(pip *)|Bash(uv *)|Bash(go *)|Bash(golangci-lint *)|Bash(cat *)|Bash(rg *)|Bash(grep *)|Bash(ls *)",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/no-secrets.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "if": "Write(*.sql)|Edit(*.sql)|MultiEdit(*.sql)|Write(**/migrations/**)|Edit(**/migrations/**)|MultiEdit(**/migrations/**)|Write(**/schema*)|Edit(**/schema*)|MultiEdit(**/schema*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/drizzle-migration-guard.py"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/supabase-rls-reminder.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "if": "Write(*.ts)|Write(*.svelte)|Write(*.js)|Edit(*.ts)|Edit(*.svelte)|Edit(*.js)|MultiEdit(*.ts)|MultiEdit(*.svelte)|MultiEdit(*.js)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/import-path-validator.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "if": "Write(**/routes/**)|Edit(**/routes/**)|MultiEdit(**/routes/**)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/sveltekit-route-validator.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/auto-format.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "if": "Write(**/package.json)|Edit(**/package.json)|Write(**/requirements.txt)|Edit(**/requirements.txt)|Write(**/Cargo.toml)|Edit(**/Cargo.toml)|Write(**/Gemfile)|Edit(**/Gemfile)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/dependency-audit.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(pnpm build *)|Bash(pnpm check *)|Bash(vite build *)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/sveltekit-perf-guard.py"
          }
        ]
      },
      {
        "matcher": "precompact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/task-snapshot.py"
          }
        ]
      },
      {
        "matcher": "postcompact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/task-restore.py"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "backend-development@claude-code-workflows": true
  }
}
